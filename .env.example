# ── PostgreSQL ─────────────────────────────
POSTGRES_DB=bankapp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secret

# ── Shared backend config ──────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bankapp
DB_USER=postgres
DB_PASSWORD=postgres_secret

# ── Auth ───────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRE_HOURS=24